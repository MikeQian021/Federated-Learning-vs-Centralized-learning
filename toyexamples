def logisticloss(theta, X, y):
    # theta (d)
    # X (N times d)
    f = X @ theta # N 
    loss = -f * torch.tensor(y, dtype=torch.float64) + torch.nn.functional.softplus(f) #torch.log(1.0 + torch.exp(f))
    return loss.sum(axis=0)

