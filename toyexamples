def logisticloss(theta, X, y):
    f = X @ theta.reshape(X.shape[1], y.shape[1]) # N times C
    loss = -torch.sum(f * y, axis=1) + torch.logsumexp(f, axis=1)
    return loss.sum(axis=0)

